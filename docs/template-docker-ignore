# Template for <root-dir>/.dockerignore when building:
#
#   cd <root-dir>
#   docker build -f docker/Dockerfile.test_0626 .
#
# Assumption:
#   A full copy of this repo lives at:
#     <root-dir>/rl-trade-trainer
#
# If the folder name differs, update Dockerfile ARG RL_TRADE_TRAINER_DIR and
# mirror that folder name in the allowlist below.

# Ignore everything by default. The image should not receive Freqtrade sqlite
# files, live configs, exchange secrets, optimization outputs, reports, virtual
# environments, git metadata, or research artifacts.
*

# Keep the Dockerfile directory available.
!docker/
!docker/Dockerfile.test_0626

# Keep only the Karakana package needed for runtime installation. The
# Dockerfile also copies only these paths explicitly; this allowlist keeps the
# context small and prevents accidental transfer of large artifacts.
!rl-trade-trainer/
!rl-trade-trainer/karakana/
!rl-trade-trainer/karakana/pyproject.toml
!rl-trade-trainer/karakana/README.md
!rl-trade-trainer/karakana/karakana/
!rl-trade-trainer/karakana/karakana/**
!rl-trade-trainer/karakana/config/
!rl-trade-trainer/karakana/config/**

# Explicitly keep generated/runtime state out, even if future allowlist rules
# are broadened.
**/.git/
**/.venv/
**/__pycache__/
**/.pytest_cache/
**/.ruff_cache/
**/.mypy_cache/
**/.DS_Store
**/*.pyc
**/*.pyo
**/*.log
**/*.sqlite
**/*.sqlite-*
**/*.db
**/*.pt
**/*.pkl
**/*.csv
**/*.jsonl

# Exclude Freqtrade and repo runtime state.
user_data/
user_data/**
**/user_data/
**/user_data/**
freqtrade/user_data/
freqtrade/user_data/**
rl-trade-trainer/user_data/
rl-trade-trainer/user_data/**
